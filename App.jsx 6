const CONTOURS = [
  { id: "lifeworlds",  word: "lifeworlds",  group: 1, strap: "The complex whole of lived relations", desc: "Lifeworlds are the shifting weave of everyday life as it is lived and made meaningful. They include streets, homes, and routines, but also habits, symbols, and shared values that hold communities toge" +
