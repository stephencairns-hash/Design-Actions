//  Prompt grid with touch drag-to-reorder
function PromptGrid({ journey, onRemove, onReorder }) {
  const [dragging, setDragging] = useState(null);
  const [dragOver, setDragOver]   = useState(null);
  const touchY = React.useRef(null);
  const rowRefs = React.useRef({});

  const getStepAtY = (y) => {
    for (const [id, el] of Object.entries(rowRefs.current)) {
      if (!el) continue;
      const rect = el.getBoundingClientRect();
      if (y >= rect.top && y <= rect.bottom) return id;
    }
    return null;
  };

  const onTouchStart = (e, id) => {
    touchY.current = e.touches[0].clientY;
    setDragging(id);
  };

  const onTouchMove = (e) => {
    e.preventDefault();
    const y = e.touches[0].clientY;
    const over = getStepAtY(y);
    if (over) setDragOver(over);
  };

  const onTouchEnd = () => {
    if (dragging && dragOver && dragging !== dragOver) {
      onReorder(dragging, dragOver);
    }
    setDragging(null);
    setDragOver(null);
    touchY.current = null;
  };

  return (
    <div style={{ display:"flex", flexDirection:"column", gap:G }}>
      {journey.map((step) => {
        const cueMeta     = { pos:getItemPos(step.cue,     "cue"),     side:"left"  };
        const contourMeta = { pos:getItemPos(step.contour, "contour"), side:"right" };
        const isDragOver  = dragOver === step.id;
        const isDragging  = dragging === step.id;
        return (
          <div
            key={step.id}
            ref={el => rowRefs.current[step.id] = el}
            onTouchStart={e => onTouchStart(e, step.id)}
            onTouchMove={onTouchMove}
            onTouchEnd={onTouchEnd}
            style={{
              opacity: isDragging ? 0.4 : 1,
              outline: isDragOver ? "2px solid #1a1a2e" : "none",
              borderRadius:R, transition:"opacity .15s",
              touchAction:"none",
            }}>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:G, background:GL }}>
              <JCell item={step.cue}     type="cue"     pos={cueMeta.pos}     side={cueMeta.side}     onRemove={() => onRemove(step.id)} showRemove={true}  />
              <JCell item={step.contour} type="contour" pos={contourMeta.pos} side={contourMeta.side} onRemove={() => onRemove(step.id)} showRemove={false} />
            </div>
          </div>
        );
      })}
      <HereNowTab journey={journey} />
    </div>
  );
}


// --- Here Now tab pair --------------------------------------------------------
function HereNowTab({ journey }) {
  const BG    = "#ebe8e3";
  const TINT  = "#ebe8e3";
  const [activeTab, setActiveTab] = useState(null);
  const [placeName, setPlaceName] = useState("");
  const [locLoading, setLocLoading] = useState(false);
  const [aiText, setAiText]   = useState("");
  const [aiStatus, setAiStatus] = useState("idle");

  const getLocation = async () => {
    if (placeName) return placeName;
    setLocLoading(true);
    let name = "your current location";
    try {
      const pos = await new Promise((res, rej) =>
        navigator.geolocation.getCurrentPosition(res, rej, { timeout:6000 })
      );
      const { latitude:lat, longitude:lon } = pos.coords;
      try {
        const r = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json`);
        const d = await r.json();
        const a = d.address || {};
        name = [a.suburb, a.city||a.town||a.village, a.country].filter(Boolean).join(", ");
      } catch { name = `${lat.toFixed(3)}, ${lon.toFixed(3)}`; }
    } catch {
      try {
        const r = await fetch("https://ipapi.co/json/");
        const d = await r.json();
        name = [d.city, d.country_name].filter(Boolean).join(", ");
      } catch {}
    }
    setPlaceName(name);
    setLocLoading(false);
    return name;
  };

  const generateBrief = async () => {
    if (aiStatus === "thinking") return;
    setAiStatus("thinking");
    setAiText("");
    const place = await getLocation();
    const step  = journey[0];
    const pairNames = `${step.cue.word} -- ${step.contour.word}`;
    const pairs = `${step.cue.word} (cue): ${step.cue.desc.replace(/\n\n/g, " ")}\n${step.contour.word} (contour): ${step.contour.desc.replace(/\n\n/g, " ")}`;
    const prompt = `You are a design advisor working with a toolkit called Design Actions. Cues are verbs that orient design action. Contours are nouns that define the terrain of inquiry.\n\nThe user is at: ${place}.\nTheir selected pair: ${pairNames}\n\nFull definitions:\n${pairs}\n\nWrite a
      short, evocative, place-specific text of around 150-200 words that interprets this design action pair for this specific location right now. Be concrete and grounded. Write as flowing prose, no bullet points.`;
    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:1000, messages:[{ role:"user", content:prompt }] }),
      });
      if (!response.ok) throw new Error(`API error ${response.status}`);
      const data   = await response.json();
      const result = data.content?.find(b => b.type === "text")?.text || "";
      if (!result) throw new Error("empty");
      setAiText(result);
      setAiStatus("done");
    } catch {
      setAiText("Something went wrong. Tap now to retry.");
      setAiStatus("error");
    }
  };

  const handleTab = (tab) => {
    if (activeTab === tab) { setActiveTab(null); return; }
    setActiveTab(tab);
    if (tab === "here" && !placeName) getLocation();
    if (tab === "now"  && aiStatus === "idle") generateBrief();
  };

  const copyText = () => navigator.clipboard?.writeText(aiText);

  return (
    <div style={{ marginTop:G }}>
      {/* Tab row -- block colour, same language as front page */}
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:G, background:GL }}>
        <button onClick={() => handleTab("here")} style={{
          background: TINT,
          height:50, border:"none", cursor:"pointer",
          display:"flex", alignItems:"center", justifyContent:"center",
          borderBottom: activeTab === "here" ? "2px solid transparent" : activeTab === "now" ? "2px solid #fff" : "none",
          opacity: activeTab === "now" ? 0.5 : 1,
          transition:"opacity .2s",
        }}>
          <span style={{ fontSize:15, fontWeight:400, color:"#1a1a1a", letterSpacing:"-0.01em" }}>here</span>
        </button>
        <button onClick={() => handleTab("now")} style={{
          background: TINT,
          height:50, border:"none", cursor:"pointer",
          display:"flex", alignItems:"center", justifyContent:"center",
          borderBottom: activeTab === "now" ? "2px solid transparent" : activeTab === "here" ? "2px solid #fff" : "none",
          opacity: activeTab === "here" ? 0.5 : 1,
          transition:"opacity .2s",
        }}>
          <span style={{ fontSize:15, fontWeight:400, color:"#1a1a1a", letterSpacing:"-0.01em" }}>now</span>
        </button>
      </div>

      {/* Content -- light grey panel, generous scrollable space */}
      {activeTab && (
        <div style={{
          background: BG,
          padding:"20px 20px 28px",
          animation:"openCard .2s ease",
          overflowY:"auto",
          WebkitOverflowScrolling:"touch",
        }}>
          {activeTab === "here" && (
            <>
              <p style={{ fontSize:9, letterSpacing:"0.2em", textTransform:"uppercase", color:"#aaa", marginBottom:10 }}>location</p>
              {locLoading
                ? <p style={{ fontSize:13, fontWeight:300, color:"#bbb" }}>locating...</p>
                : <p style={{ fontSize:15, fontWeight:400, color:"#1a1a1a", lineHeight:1.5 }}>{placeName || "tap now to generate a brief"}</p>
