// --- Mix grid (all 15 pairs, selectable + draggable) ----
function MixGrid({ order, openItem, onOpen, selCue, selContour, onSelect, onReorder }) {
  const [dragging, setDragging] = useState(null);
  const [dragOver, setDragOver] = useState(null);
  const rowRefs = React.useRef({});

  const getIdxAtY = (y) => {
    for (const [idx, el] of Object.entries(rowRefs.current)) {
      if (!el) continue;
      const rect = el.getBoundingClientRect();
      if (y >= rect.top && y <= rect.bottom) return parseInt(idx);
    }
    return null;
  };

  const onTouchStart = (e, idx) => { setDragging(idx); };
  const onTouchMove  = (e) => {
    e.preventDefault();
    const over = getIdxAtY(e.touches[0].clientY);
    if (over !== null) setDragOver(over);
  };
  const onTouchEnd = () => {
    if (dragging !== null && dragOver !== null && dragging !== dragOver) {
      onReorder(dragging, dragOver);
    }
    setDragging(null); setDragOver(null);
  };

  return (
    <div style={{ display:"flex", flexDirection:"column", gap:G }}>
      {order.map((pairIdx, sortIdx) => {
        const pair    = NATURAL_PAIRS[pairIdx];
        const cue     = pair.cue;
        const contour = pair.contour;
        const g       = getGroup(cue.group);
        const pos     = rowPos(pairIdx % 3);
        const rowOpen = (openItem?.id === cue.id || openItem?.id === contour?.id) ? openItem : null;
        const isDragOver = dragOver === sortIdx;
        const isDragging = dragging === sortIdx;

        return (
          <div
            key={pairIdx}
            ref={el => rowRefs.current[sortIdx] = el}
            onTouchStart={e => onTouchStart(e, sortIdx)}
            onTouchMove={onTouchMove}
            onTouchEnd={onTouchEnd}
            style={{
              opacity: isDragging ? 0.4 : 1,
              outline: isDragOver ? "2px solid #1a1a2e" : "none",
              borderRadius:R, transition:"opacity .15s",
              touchAction:"none",
            }}>
            <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:G, background:GL }}>
              <CardRow
                cue={cue} contour={contour} pos={pos} group={g}
                selCue={selCue} selContour={selContour} onSelect={onSelect}
                openItem={rowOpen} onOpen={onOpen}
              />
            </div>
          </div>
        );
      })}
    </div>
  );
}

// --- App ----------------------------------------
export default function DesignActions() {
  const [screen, setScreen]         = useState("home");
  const [openItem, setOpenItem]     = useState(null);
  const [mixOpen, setMixOpen]       = useState(null);
  const [selCue, setSelCue]         = useState(null);
  const [selContour, setSelContour] = useState(null);
  const [pairs, setPairs]           = useState([]);
  const [order, setOrder]           = useState(NATURAL_PAIRS.map((_, i) => i));

  const fg = "#1a1a1a";

  const handleHomeOpen = (item) => setOpenItem(prev => prev?.id === item?.id ? null : item);
  const handleMixOpen  = (item) => setMixOpen(prev => prev?.id === item?.id ? null : item);

  const handleSelect = (type, item) => {
    if (type === "cue")     setSelCue(prev => prev?.id === item.id ? null : item);
    if (type === "contour") setSelContour(prev => prev?.id === item.id ? null : item);
  };

  const addPair = () => {
    if (!selCue || !selContour || pairs.length >= 6) return;
    setPairs(p => [...p, { cue:selCue, contour:selContour, id:Date.now() }]);
    setSelCue(null);
    setSelContour(null);
  };

  const reorderPair = (fromIdx, toIdx) => {
    setOrder(prev => {
      const next = [...prev];
      const [moved] = next.splice(fromIdx, 1);
      next.splice(toIdx, 0, moved);
      return next;
    });
  };

  const randomPair = () => {
    if (pairs.length >= 6) return;
    const c  = CUES[Math.floor(Math.random() * CUES.length)];
    const co = CONTOURS[Math.floor(Math.random() * CONTOURS.length)];
    setPairs(p => [...p, { cue:c, contour:co, id:Date.now() }]);
  };

  const naturalPair = () => {
    if (pairs.length >= 6) return;
    const used = new Set(pairs.map(s => s.cue.id));
    const next = NATURAL_PAIRS.find(p => !used.has(p.cue.id));
    if (!next) return;
    setPairs(p => [...p, { cue:next.cue, contour:next.contour, id:Date.now() }]);
  };

  const bothSelected = !!(selCue && selContour);

  return (
    <div style={{ background:"#ffffff", minHeight:"100vh", color:fg, maxWidth:390, margin:"0 auto", fontFamily:"Inter,sans-serif" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&display=swap');
        *{box-sizing:border-box;margin:0;padding:0;}
        button{cursor:pointer;font-family:Inter,sans-serif;}
        ::-webkit-scrollbar{display:none;}
        @keyframes openCard{from{opacity:0;transform:scaleY(0.96)}to{opacity:1;transform:scaleY(1)}}
        @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
      `}</style>

      {/* HOME -- reading only, no selection */}
      {screen === "home" && (
        <div style={{ paddingBottom:90 }}>
          <div style={{ padding:"52px 24px 28px" }}>
            <h1 style={{ fontSize:36, fontWeight:300, color:fg, letterSpacing:"-0.03em", lineHeight:1.0, marginBottom:10 }}>
              Design<br/>Actions
            </h1>
            <p style={{ fontSize:11, fontWeight:300, color:"#888", letterSpacing:"0.12em", textTransform:"uppercase", lineHeight:1.7 }}>
              creative rigour<br/>for complex challenges
            </p>
            <p style={{ fontSize:10, fontWeight:300, color:"#bbb", letterSpacing:"0.08em", textTransform:"uppercase", marginTop:14 }}>
              tap to read
            </p>
          </div>
          <div style={{ padding:"0 24px" }}>
            <ReadGrid openItem={openItem} onOpen={handleHomeOpen} selCue={selCue} selContour={selContour} onSelect={handleSelect}/>
          </div>
        </div>
      )}

      {/* MIX -- all 15 pairs, selectable, draggable, here-now */}
      {screen === "prompt" && (
        <div style={{ paddingBottom:100 }}>
          {/* Header -- just the title, no buttons */}
          <div style={{ padding:"52px 24px 24px" }}>
            <h2 style={{ fontSize:28, fontWeight:300, color:fg, letterSpacing:"-0.025em", lineHeight:1.0, marginBottom:6 }}>prompt</h2>
            <p style={{ fontSize:11, fontWeight:300, color:"#bbb", letterSpacing:"0.02em" }}>
              tap here . now to generate
            </p>
          </div>

          <div style={{ padding:"0 24px" }}>
            {/* Current pair */}
            {selCue && selContour ? (
              <div style={{ marginBottom:0 }}>
                <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:G, background:GL }}>
                  <div style={{ background:getGroup(selCue.group).tint, borderRadius:cr(getItemPos(selCue,"cue"),"left"), height:64, display:"flex", alignItems:"center", justifyContent:"center" }}>
                    <span style={{ fontSize:17, fontWeight:400, color:"#1a1a1a", letterSpacing:"-0.02em",
                      borderBottom:"2.5px solid #1a1a1a", paddingBottom:1 }}>{selCue.word}</span>
                  </div>
                  <div style={{ background:getGroup(selContour.group).tint, borderRadius:cr(getItemPos(selContour,"contour"),"right"), height:64, display:"flex", alignItems:"center", justifyContent:"center" }}>
                    <span style={{ fontSize:17, fontWeight:400, color:"#1a1a1a", letterSpacing:"-0.02em",
                      borderBottom:"2.5px solid #1a1a1a", paddingBottom:1 }}>{selContour.word}</span>
                  </div>
                </div>
              </div>
            ) : (
              <div style={{ padding:"24px 0", textAlign:"center" }}>
                <p style={{ fontSize:12, color:"#ccc", letterSpacing:"0.06em", textTransform:"uppercase" }}>
                  no pair selected
                </p>
                <p style={{ fontSize:10, color:"#ddd", marginTop:6 }}>underline words on the read page to begin</p>
              </div>
            )}

            {/* Here Now -- pink tabs, sits directly below pair */}
            {selCue && selContour && (
              <HereNowTab journey={[{ cue:selCue, contour:selContour, id:1 }]} accentColor={"#aaa"}/>
            )}
          </div>
        </div>
      )}

      {/* NAV */}
      <div style={{ position:"fixed", bottom:0, left:"50%", transform:"translateX(-50%)", width:"100%", maxWidth:390, zIndex:100, background:"#fff", borderTop:"1px solid #e0ddd8", padding:"10px 24px 28px", display:"flex", alignItems:"center", justifyContent:"space-between" }}>
<div style={{ flex:1 }}/>
        {screen === "home" ? (
          <button onClick={() => setScreen("prompt")} style={{
            background: bothSelected ? "#1a1a2e" : "#e0ddd8",
            color: bothSelected ? "#fff" : "#aaa",
            border:"none", borderRadius:20, padding:"7px 18px",
            fontSize:11, fontWeight:500, letterSpacing:"0.04em", flexShrink:0,
            transition:"background .25s, color .25s",
          }}>
            prompt
          </button>
        ) : (
          <div style={{ display:"flex", alignItems:"center", gap:6, flexShrink:0, flexWrap:"wrap", justifyContent:"flex-end" }}>
            {[
              { label:"+ natural", fn: () => { const n=NATURAL_PAIRS[0]; handleSelect("cue",n.cue); handleSelect("contour",n.contour); }},
              { label:"+ random",  fn: () => { handleSelect("cue",CUES[Math.floor(Math.random()*CUES.length)]); handleSelect("contour",CONTOURS[Math.floor(Math.random()*CONTOURS.length)]); }},
              { label:"back", fn: () => { const i=NATURAL_PAIRS.findIndex(p=>p.cue.id===selCue?.id); const p=NATURAL_PAIRS[(i-1+NATURAL_PAIRS.length)%NATURAL_PAIRS.length]; handleSelect("cue",p.cue); handleSelect("contour",p.contour); }},
              { label:"next", fn: () => { const i=NATURAL_PAIRS.findIndex(p=>p.cue.id===selCue?.id); const n=NATURAL_PAIRS[(i+1)%NATURAL_PAIRS.length]; handleSelect("cue",n.cue); handleSelect("contour",n.contour); }},
            ].map(t => (
              <button key={t.label} onClick={t.fn} style={{ fontSize:10, color:"#888", border:"1px solid #e0ddd8", borderRadius:20, padding:"5px 9px", background:"none", cursor:"pointer" }}>{t.label}</button>
            ))}
            <button onClick={() => setScreen("home")} style={{ background:"#1a1a2e", color:"#fff", border:"none", borderRadius:20, padding:"7px 14px", fontSize:11, fontWeight:500, letterSpacing:"0.04em", cursor:"pointer" }}>
              read
            </button>
          </div>
        )}
      </div>
    </div>
  );
}
