            <>
              <p style={{ fontSize:9, letterSpacing:"0.2em", textTransform:"uppercase", color:"#aaa", marginBottom:10 }}>design brief</p>
              {aiStatus === "thinking" && (
                <div style={{ display:"flex", alignItems:"center", gap:8 }}>
                  <div style={{ width:5, height:5, borderRadius:"50%", background:"#ccc", animation:"pulse 1s infinite" }}/>
